doctype html
html
  head
    title= title
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    header.bg-primary.text-white.text-center.p-3
      h1 Galeria

    nav.navbar.navbar-expand.navbar-dark.bg-dark
      div.container-fluid
        ul.navbar-nav.me-auto
          li.nav-item
            a.nav-link(href='/') Strona główna
            if loggedUser
            li.nav-item
              a.nav-link(href='/galleries') Galerie
            li.nav-item
              a.nav-link(href='/galleries/gallery_add') Dodaj galerię
            li.nav-item
              a.nav-link(href='/images/image_upload') Dodaj obrazek

        ul.navbar-nav
          if loggedUser
            li.nav-item
            span.nav-link.text-white | Zalogowano jako: #{loggedUser} |
            if loggedUser === 'admin'
              li.nav-item
                a.nav-link.text-warning(href='/users/user_list') Lista użytkowników
              li.nav-item
                a.nav-link.text-warning(href='/users/user_add') Dodaj nowego użytkownika
            li.nav-item
              a.nav-link.text-danger(href='/users/user_logout') Wyloguj się 
          else
            li.nav-item
              a.nav-link.text-success(href='/users/user_login') Zaloguj się

    div.container.mt-4
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")