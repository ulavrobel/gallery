extends layout

block content
  h2= title
  hr

  if messages
    div.alert.alert-danger
      ul.mb-0
        for message in messages
          li!= message

  form(method='POST' action='' style="max-width: 400px;")
    div.mb-3
      label.form-label(for='username') Nazwa użytkownika:
      input#username.form-control(type='text', name='username', required)
      
    div.mb-3
      label.form-label(for='password') Hasło:
      input#password.form-control(type='password', name='password', autocomplete='off', required)
      
    button.btn.btn-primary(type='submit') Zaloguj się