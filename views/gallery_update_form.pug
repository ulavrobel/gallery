extends layout

block content
  h2= title
  hr

  if messages
    div.alert.alert-info
      ul.mb-0
        for message in messages
          li!= message

  form(method='POST' action=`/galleries/gallery_update?gallery_id=${gallery._id}` style="max-width: 600px;")
    div.mb-3
      label.form-label(for='g_name') Nazwa galerii:
      input#g_name.form-control(type='text', name='g_name', required, value=gallery.name)
    
    div.mb-3
      label.form-label(for='g_description') Opis:
      input#g_description.form-control(type='text', name='g_description', required, value=gallery.description)
    
    div.mb-3
      label.form-label(for='g_user') Twórca:
      select#g_user.form-select(name='g_user', required)
        for user in users
          if gallery.owner && gallery.owner.toString() === user._id.toString()
            option(value=user._id, selected) #{user.last_name} #{user.first_name} (#{user.username})
          else
            option(value=user._id) #{user.last_name} #{user.first_name} (#{user.username})
            
    button.btn.btn-primary(type='submit') Zapisz zmiany